# to get all the running pods 
kubectl get pods
NAME                                READY   STATUS    RESTARTS   AGE
nginx-deployment-595b977765-qcmth   1/1     Running   0          14m

# to get all running services 
kubectl get svc
NAME             TYPE        CLUSTER-IP     EXTERNAL-IP   PORT(S)          AGE
kubernetes       ClusterIP   10.96.0.1      <none>        443/TCP          41h
nginx-services   NodePort    10.109.42.94   <none>        8080:32096/TCP   22m

# to get all the deployment 
kubectl get deployments.apps 
NAME               READY   UP-TO-DATE   AVAILABLE   AGE
nginx-deployment   1/1     1            1           22m

# expose or test the service 
minikube ssh
Linux minikube 6.8.0-107-generic #107~22.04.1-Ubuntu SMP PREEMPT_DYNAMIC Wed Mar 18 23:40:43 UT

# to see the output of the nginx server
curl 10.109.42.94:8080

another way to test the output 
minikube service nginx-services 
curl http://192.168.49.2:32096 